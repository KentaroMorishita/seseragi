// Lesson 08: structured Fiber、Deferred、join
// Prerequisite: Lesson 06

import * as deferred from "std/deferred"
import * as effects from "std/effect"

pub effect fn main -> Unit
with Console
fails ConsoleError =
  do {
    gate <- deferred.make<Never, Int> ()

    worker <- effects.fork $ do {
      value <- deferred.await gate
      println $ `worker: ${value}`
    }

    deferred.succeed 42 gate
    effects.join worker
  }

// Expected stdout:
// worker: 42
