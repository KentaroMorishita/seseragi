// Arrayの点数を、標準Reducible instanceとcurriedな(+)で畳み込みます。
// 合計値を判定し、結果をEffect経由でConsoleへ出力するサンプルです。

fn total scores: Array<Int> -> Int =
  reduce 0 (+) scores

fn renderScore totalScore: Int -> String =
  if totalScore == 108 then
    "Score total: 108 — perfect checksum!"
  else
    "The score checksum did not match."

pub effect fn main -> Unit
with Console
fails ConsoleError =
  [4, 8, 15, 16, 23, 42]
  |> total
  |> renderScore
  |> println
