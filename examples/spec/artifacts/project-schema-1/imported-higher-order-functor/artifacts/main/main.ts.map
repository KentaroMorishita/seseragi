import { transform } from "./domain"

fn increment value: Int -> Int = value + 1

fn render value: Maybe<Int> -> String =
  match value {
    Nothing -> "Nothing"
    Just 42 -> "Imported mapper: Just 42"
    Just _ -> "Imported mapper: another value"
  }

pub effect fn main =
  Just 41
  |> transform increment
  |> render
  |> println
