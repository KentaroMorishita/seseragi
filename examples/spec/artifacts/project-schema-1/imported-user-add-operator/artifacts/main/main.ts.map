import { Points, Score } from "./domain"

fn addBonus bonus: Int -> score: Score -> Score =
  score + bonus

fn total values: Array<Int> -> Score =
  values
  |> reduce (Points 0) (+)
  |> addBonus 0

fn render score: Score -> String =
  match score {
    Points 42 -> "Imported Add: 42"
    _ -> "unexpected score"
  }

pub effect fn main =
  [10, 12, 20]
  |> total
  |> render
  |> println
