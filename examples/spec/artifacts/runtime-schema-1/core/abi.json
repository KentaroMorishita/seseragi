{
  "schema": 1,
  "identity": "@seseragi/runtime",
  "abiMajor": 1,
  "targetFamily": "typescript",
  "features": [
    {
      "id": "core.int64",
      "kind": "value-representation",
      "typescript": "bigint",
      "boundary": "signed-64",
      "import": null
    },
    {
      "id": "core.unit",
      "kind": "value-representation",
      "typescript": "undefined",
      "boundary": "unit",
      "import": null
    },
    {
      "id": "core.string",
      "kind": "value-representation",
      "typescript": "string",
      "boundary": "unicode-scalar-string",
      "import": null
    },
    {
      "id": "core.bool",
      "kind": "value-representation",
      "typescript": "boolean",
      "boundary": "boolean",
      "import": null
    },
    {
      "id": "effect.core.succeed",
      "kind": "runtime-helper",
      "typescript": "function",
      "boundary": "A -> Effect<{}, Never, A>",
      "import": {
        "module": "@seseragi/runtime/effect",
        "export": "succeed"
      }
    },
    {
      "id": "effect.core.flatMap",
      "kind": "runtime-helper",
      "typescript": "function",
      "boundary": "Effect<R1, E1, A> -> (A -> Effect<R2, E2, B>) -> Effect<R1 & R2, E1 | E2, B>",
      "import": {
        "module": "@seseragi/runtime/effect",
        "export": "flatMap"
      }
    },
    {
      "id": "effect.console.print",
      "kind": "runtime-helper",
      "typescript": "function",
      "boundary": "Effect<{ console: Console }, ConsoleError, Unit>",
      "import": {
        "module": "@seseragi/runtime/console",
        "export": "print"
      }
    },
    {
      "id": "effect.console.println",
      "kind": "runtime-helper",
      "typescript": "function",
      "boundary": "Effect<{ console: Console }, ConsoleError, Unit>",
      "import": {
        "module": "@seseragi/runtime/console",
        "export": "println"
      }
    },
    {
      "id": "effect.stdin.readLine",
      "kind": "runtime-helper",
      "typescript": "function",
      "boundary": "Effect<{ stdin: Stdin }, StdinError, Maybe<String>>",
      "import": {
        "module": "@seseragi/runtime/stdin",
        "export": "readLine"
      }
    }
  ]
}
