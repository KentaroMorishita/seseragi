pub type Hand =
  | Rock
  | Paper
  | Scissors

pub type HandInputError =
  | UnknownHand String

pub fn parseHand input: String -> Either<HandInputError, Hand> =
  match input {
    "rock" -> Right Rock
    "paper" -> Right Paper
    "scissors" -> Right Scissors
    other -> Left (UnknownHand other)
  }
