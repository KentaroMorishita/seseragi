{
  "schema": 1,
  "module": "artifact/collection-access",
  "target": "typescript-es2022",
  "runtime": {
    "identity": "@seseragi/runtime",
    "abiMajor": 1,
    "requirements": [
      "core.list",
      "core.unit",
      "core.int64",
      "core.list.from-array",
      "core.string",
      "core.int64.show",
      "core.bool",
      "core.maybe",
      "core.adt",
      "core.array.length",
      "core.list.length",
      "core.array.is-empty",
      "core.array.get",
      "core.int64.subtract",
      "core.array.head",
      "core.array.tail",
      "core.list.is-empty",
      "core.list.get",
      "core.list.head",
      "core.list.tail"
    ]
  },
  "exports": [
    "collectionAccessResults"
  ],
  "outputs": {
    "typescript": "main.ts",
    "sourceMap": "main.ts.map"
  }
}
