{
  "schema": 1,
  "module": "artifact/int-arithmetic",
  "target": "typescript-es2022",
  "runtime": {
    "identity": "@seseragi/runtime",
    "abiMajor": 1,
    "requirements": [
      "core.int64",
      "core.int64.add",
      "core.int64.subtract",
      "core.int64.multiply",
      "core.int64.divide",
      "core.int64.remainder",
      "core.int64.power"
    ]
  },
  "exports": [
    "add",
    "subtract",
    "multiply",
    "divide",
    "remainder",
    "power"
  ],
  "outputs": {
    "typescript": "main.ts",
    "sourceMap": "main.ts.map"
  }
}
