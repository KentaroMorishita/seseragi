pub struct Player {
  name: String,
  score: Int,
}

fn improve player: Player -> Player =
  Player {
    ...player,
    score: 42,
  }

fn render player: Player -> String =
  match player {
    Player { name, score: 42 } -> `${name}: perfect ${player.score}`
    Player { name, score } -> `${name}: keep training at ${score}`
  }

pub effect fn main =
  Player { name: "Mio", score: 12 }
  |> improve
  |> render
  |> println
