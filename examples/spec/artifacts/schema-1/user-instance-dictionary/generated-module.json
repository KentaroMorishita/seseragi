{
  "schema": 1,
  "module": "artifact/user-instance-dictionary",
  "target": "typescript-es2022",
  "runtime": {
    "identity": "@seseragi/runtime",
    "abiMajor": 1,
    "requirements": [
      "core.adt",
      "core.string",
      "core.unit",
      "effect.console.println"
    ]
  },
  "exports": [
    "Active",
    "Paused",
    "label",
    "status",
    "main"
  ],
  "instances": [
    {
      "identity": "artifact/user-instance-dictionary::trait(Render)<artifact/user-instance-dictionary::Badge>",
      "trait": "Render",
      "arguments": [
        {
          "kind": "reference",
          "name": "Badge",
          "arguments": []
        }
      ],
      "dictionaryExport": "__ssrg$instance$Render$0"
    }
  ],
  "outputs": {
    "typescript": "main.ts",
    "sourceMap": "main.ts.map"
  }
}
