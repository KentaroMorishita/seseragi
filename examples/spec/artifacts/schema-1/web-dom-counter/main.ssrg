import * as dom from "std/web/dom"
import * as html from "std/web/html"

type Mode =
  | Ready
  | Focusing
  | Resting

type Action =
  | StartFocus
  | TakeBreak
  | Reset

let initialMode: Mode = Ready

let pageStyle =
  html.style {
    background: "linear-gradient(135deg, #d1fae5 0%, #f8fafc 48%, #dbeafe 100%)",
    minHeight: "100vh",
    padding: "32px"
  }

let cardStyle =
  html.style {
    variables: { cardShadow: "0 24px 64px #0f172a24" },
    backgroundColor: "#ffffff",
    border: "1px solid #ffffffcc",
    borderRadius: "28px",
    boxShadow: "var(--card-shadow)",
    padding: "32px"
  }

let trackStyle =
  html.style {
    backgroundColor: "#e2e8f0",
    borderRadius: "999px",
    height: "10px",
    overflow: "hidden"
  }

fn label mode: Mode -> String =
  match mode {
    Ready -> "READY"
    Focusing -> "FOCUS"
    Resting -> "BREAK"
  }

fn title mode: Mode -> String =
  match mode {
    Ready -> "Choose your rhythm"
    Focusing -> "Deep work in progress"
    Resting -> "Pause with purpose"
  }

fn guidance mode: Mode -> String =
  match mode {
    Ready -> "Pick a mode and let a typed action update the Signal."
    Focusing -> "One task. No tab hopping. You have got this."
    Resting -> "Look away from the screen and take a slow breath."
  }

fn accent mode: Mode -> String =
  match mode {
    Ready -> "#475569"
    Focusing -> "#059669"
    Resting -> "#2563eb"
  }

fn progress mode: Mode -> String =
  match mode {
    Ready -> "18%"
    Focusing -> "82%"
    Resting -> "46%"
  }

fn progressStyle mode: Mode -> html.Style =
  html.style {
    backgroundColor: accent mode,
    borderRadius: "999px",
    height: "100%",
    transition: "all 240ms ease",
    width: progress mode
  }

fn badgeStyle mode: Mode -> html.Style =
  html.style {
    backgroundColor: accent mode,
    borderRadius: "999px",
    color: "#ffffff",
    fontSize: "12px",
    fontWeight: "700",
    letterSpacing: "0.12em",
    padding: "6px 12px"
  }

fn actionStyle action: Action -> html.Style =
  match action {
    StartFocus ->
      html.style { backgroundColor: "#059669", color: "#ffffff" }
    TakeBreak ->
      html.style { backgroundColor: "#2563eb", color: "#ffffff" }
    Reset ->
      html.style { backgroundColor: "#f1f5f9", color: "#334155" }
  }

fn actionButton id: String
  -> text: String
  -> action: Action
  -> html.Html<Action> =
  html.button {
    id,
    onClick: action,
    className: "w-full rounded-xl border-0 px-4 py-3 font-semibold transition hover:shadow-lg",
    style: actionStyle action,
    children: text
  }

fn view mode: Mode -> html.Html<Action> =
  html.main {
    style: pageStyle,
    children: [
      html.section {
        className: "mx-auto max-w-lg",
        style: cardStyle,
        children: [
          html.div {
            className: "mb-6 flex items-center justify-between",
            children: [
              html.span {
                style: badgeStyle mode,
                children: label mode
              },
              html.span {
                className: "text-sm font-semibold text-slate-500",
                children: "SESERAGI FLOW"
              }
            ]
          },
          html.h1 {
            className: "m-0 text-3xl font-bold text-slate-900 sm:text-4xl",
            children: title mode
          },
          html.p {
            className: "mb-6 mt-4 text-lg text-slate-700",
            children: guidance mode
          },
          html.div {
            style: trackStyle,
            children: html.div {
              style: progressStyle mode,
              children: ""
            }
          },
          html.div {
            className: "mt-6 grid grid-cols-1 gap-2 sm:grid-cols-3",
            children: [
              actionButton "focus" "Start focus" StartFocus,
              actionButton "break" "Take a break" TakeBreak,
              actionButton "reset" "Reset the flow" Reset
            ]
          }
        ]
      }
    ]
  }

fn update action: Action -> mode: Mode -> Mode =
  match action {
    StartFocus -> Focusing
    TakeBreak -> Resting
    Reset -> Ready
  }

pub effect fn main =
  dom.app {
    target: "#app",
    initial: initialMode,
    update,
    view
  }
