fn profile name: String -> score: Int -> { name: String, score: Int } =
  { name, score }

fn displayName user: { name: String } -> String =
  user.name

fn renderProfile user: { name: String } -> String =
  "Record profile: " + displayName user

pub effect fn main =
  profile "Mio" 42
  |> renderProfile
  |> println
