import { forEach } from "std/effect"

fn fizzBuzz number: Int -> String =
  match (number % 3, number % 5) {
    (0, 0) -> "FizzBuzz"
    (0, _) -> "Fizz"
    (_, 0) -> "Buzz"
    _ -> show number
  }

pub fn main unit: Unit
  -> Effect<{ console: Console }, ConsoleError, Unit> =
  [number | number <- 1..=100]
    |> forEach (\number -> println (fizzBuzz number))

// Expected stdout:
// 1から100までを一行ずつ出力する。
// 3の倍数はFizz、5の倍数はBuzz、15の倍数はFizzBuzz。
