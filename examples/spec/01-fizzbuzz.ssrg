fn fizzBuzz number: Int -> String =
  match (number % 3, number % 5) {
    (0, 0) -> "FizzBuzz"
    (0, _) -> "Fizz"
    (_, 0) -> "Buzz"
    _ -> `${number}`
  }

pub effect fn main -> Unit
with Console
fails ConsoleError =
  for number <- 1..=100 {
    println $ fizzBuzz number
  }

// Expected stdout: ./01-fizzbuzz.stdout
