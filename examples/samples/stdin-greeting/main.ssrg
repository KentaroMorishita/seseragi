type AppError deriving Show =
  | InputFailure StdinError
  | OutputFailure ConsoleError

pub effect fn main =
  do {
    maybeName <- readLine () |> mapError InputFailure
    let greeting =
      match maybeName {
        Just name -> `Hello, ${name}!`
        Nothing -> "Hello, stranger!"
      }
    println greeting |> mapError OutputFailure
  }
