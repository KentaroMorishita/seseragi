struct Score {
  value: Int,
}

impl Score {
  operator + self -> bonus: Int -> Score =
    Score { value: self.value + bonus }

  operator == self -> other: Score -> Bool =
    self.value == other.value
}

fn render score: Score -> String =
  if score == Score { value: 42 } then
    `Score: ${score.value}`
  else
    "Unexpected score"

// operator memberも通常のAdd / Eq instanceと同じ仕組みを使います。
pub effect fn main =
  Score { value: 21 } + 21
  |> render
  |> println
