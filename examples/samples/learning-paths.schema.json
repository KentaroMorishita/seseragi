{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seseragi.dev/schemas/playground-learning-paths-1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "paths"],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "const": 1 },
    "paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "summary", "samples"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "samples": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          }
        }
      }
    }
  }
}
