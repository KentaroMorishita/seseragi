{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seseragi.dev/schemas/playground-sample-1.json",
  "title": "Seseragi runnable sample",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "summary",
    "kind",
    "difficulty",
    "topics",
    "capabilities",
    "outputMode",
    "prerequisites",
    "featured",
    "files"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["lesson", "recipe", "showcase"] },
    "difficulty": { "enum": ["beginner", "intermediate", "advanced"] },
    "topics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["console", "stdin", "dom"] }
    },
    "outputMode": { "enum": ["text", "html"] },
    "prerequisites": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "featured": { "type": "boolean" },
    "isNew": { "type": "boolean" },
    "interactive": { "type": "boolean" },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "guide"],
      "properties": {
        "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "guide": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "stdin": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "expectedOutput": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        }
      }
    }
  }
}
