{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Seseragi: check workspace",
      "type": "shell",
      "command": "bun run check",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Seseragi: build Rust workspace",
      "type": "shell",
      "command": "cargo build --workspace",
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Seseragi: run current file",
      "type": "shell",
      "command": "cargo run -p seseragi-cli -- run \"${file}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
