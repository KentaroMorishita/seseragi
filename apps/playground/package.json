{
  "name": "@seseragi/playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "samples:generate": "bun ../../scripts/generate-playground-samples.ts",
    "samples:check": "bun ../../scripts/generate-playground-samples.ts --check",
    "dev": "bun run samples:generate && vite",
    "build": "bun run samples:check && vite build",
    "build:wasm": "../../scripts/build-playground-wasm.sh apps/playground/src/wasm/pkg",
    "test": "bun run samples:check && bun test",
    "typecheck": "bun run samples:check && tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/search": "^6.0.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@lezer/highlight": "^1.2.1",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vite": "^7.0.4"
  }
}
