{
  "name": "seseragi-spec-preview",
  "displayName": "Seseragi",
  "description": "Syntax highlighting and native language-server support for Seseragi",
  "version": "0.2.0",
  "publisher": "seseragi-dev",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KentaroMorishita/seseragi.git",
    "directory": "extensions/seseragi-spec-preview"
  },
  "files": [
    "dist",
    "language-configuration.json",
    "README.md",
    "syntaxes"
  ],
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:seseragi"
  ],
  "scripts": {
    "build": "esbuild extension.js --bundle --minify --platform=node --external:vscode --outfile=dist/extension.js",
    "package": "bun run build && vsce package --out ../../target/seseragi-vscode.vsix"
  },
  "contributes": {
    "languages": [
      {
        "id": "seseragi",
        "aliases": [
          "Seseragi"
        ],
        "extensions": [
          ".ssrg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "seseragi",
        "scopeName": "source.seseragi-spec-preview",
        "path": "./syntaxes/seseragi.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Seseragi",
      "properties": {
        "seseragi.languageServer.path": {
          "type": "string",
          "default": "seseragi-lsp",
          "description": "Path to the seseragi-lsp executable. Relative commands are resolved through PATH."
        }
      }
    },
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "keyword.operator.pipeline.seseragi",
            "settings": {
              "foreground": "#E5C07B",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.operator.application.seseragi",
            "settings": {
              "foreground": "#E5C07B",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.operator.generator.seseragi",
            "settings": {
              "foreground": "#C678DD",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.operator.bind.seseragi",
            "settings": {
              "foreground": "#56B6C2",
              "fontStyle": "bold"
            }
          },
          {
            "scope": [
              "keyword.operator.map.seseragi",
              "keyword.operator.apply.seseragi"
            ],
            "settings": {
              "foreground": "#56B6C2",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.operator.signal.seseragi",
            "settings": {
              "foreground": "#D19A66",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.operator.assignment.seseragi",
            "settings": {
              "foreground": "#D19A66"
            }
          },
          {
            "scope": "keyword.operator.arithmetic.seseragi",
            "settings": {
              "foreground": "#61AFEF"
            }
          },
          {
            "scope": "keyword.operator.comparison.seseragi",
            "settings": {
              "foreground": "#61AFEF"
            }
          },
          {
            "scope": [
              "keyword.operator.logical.seseragi",
              "keyword.operator.nullish-coalescing.seseragi"
            ],
            "settings": {
              "foreground": "#C678DD"
            }
          },
          {
            "scope": [
              "keyword.operator.range.seseragi",
              "keyword.operator.spread.seseragi"
            ],
            "settings": {
              "foreground": "#98C379"
            }
          },
          {
            "scope": "keyword.operator.cons.seseragi",
            "settings": {
              "foreground": "#56B6C2"
            }
          },
          {
            "scope": "keyword.operator.custom.seseragi",
            "settings": {
              "foreground": "#E06C75",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.operator.arrow.seseragi",
            "settings": {
              "foreground": "#ABB2BF"
            }
          }
        ]
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.25.0"
  }
}
