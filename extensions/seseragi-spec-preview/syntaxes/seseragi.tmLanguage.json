{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Seseragi",
  "scopeName": "source.seseragi",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#list-sugar"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#type-declarations"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.seseragi",
          "begin": "//",
          "end": "$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.seseragi",
          "match": "\\b(as|alias|deprecated|deriving|do|effect|else|fails|fn|for|foreign|from|if|impl|import|infix|infixl|infixr|instance|let|match|newtype|opaque|operator|pub|rec|struct|then|trait|type|when|where|with)\\b"
        },
        {
          "name": "storage.modifier.foreign.seseragi",
          "match": "\\b(pure|task)(?=\\s+(?:(?:constructor|method|property)\\s+)?fn\\b)|\\b(constructor|method|property)(?=\\s+fn\\b)|\\bvalue(?=\\s+[a-z][a-zA-Z0-9_]*\\s*:)|\\bnamespace(?=\\s+[a-z][a-zA-Z0-9_]*)"
        },
        {
          "name": "storage.modifier.deprecated.seseragi",
          "match": "\\bsince(?=\\s+\")"
        },
        {
          "name": "variable.language.self.seseragi",
          "match": "\\bself(?=\\s*(?::|->))"
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "meta.type-declaration.seseragi",
          "begin": "\\b(type|newtype|alias|trait)\\s+([A-Z][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.type.seseragi"
            },
            "2": {
              "name": "entity.name.type.declaration.seseragi"
            }
          },
          "end": "(?=\\n|//|/\\*)",
          "patterns": [
            {
              "name": "keyword.operator.assignment.seseragi",
              "match": "="
            },
            {
              "include": "#types"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#punctuation"
            }
          ]
        },
        {
          "name": "meta.struct-declaration.seseragi",
          "begin": "\\b(struct)\\s+([A-Z][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.struct.seseragi"
            },
            "2": {
              "name": "entity.name.type.struct.seseragi"
            }
          },
          "end": "}",
          "patterns": [
            {
              "name": "punctuation.definition.struct.begin.seseragi",
              "match": "{"
            },
            {
              "name": "variable.other.field.seseragi",
              "match": "\\b[a-z][a-zA-Z0-9_]*(?=\\s*\\??\\s*:)"
            },
            {
              "include": "#types"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.primitive.seseragi",
          "match": "\\b(Int|Float|Bool|Char|String|Unit|Never)\\b"
        },
        {
          "name": "entity.name.type.generic.seseragi",
          "match": "\\b(Maybe|Either|List|Array|Iterator|Effect|Task|Signal|MutableSignal|Stream|Fiber|Ref|Deferred|Queue|Semaphore|Html|Attribute|Style|WebUrl|DomTarget|DomMount)\\b"
        },
        {
          "name": "entity.name.type.user.seseragi",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.map.seseragi",
          "match": "<\\$>"
        },
        {
          "name": "keyword.operator.apply.seseragi",
          "match": "<\\*>"
        },
        {
          "name": "keyword.operator.spread.seseragi",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.seseragi",
          "match": "\\.\\.(=)?"
        },
        {
          "name": "keyword.operator.generator.seseragi",
          "match": "<-"
        },
        {
          "name": "keyword.operator.arrow.seseragi",
          "match": "->"
        },
        {
          "name": "keyword.operator.logical.seseragi",
          "match": "(&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.requirement-merge.seseragi",
          "match": "(?<!&)&(?!&)"
        },
        {
          "name": "keyword.operator.comparison.seseragi",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.bind.seseragi",
          "match": ">>="
        },
        {
          "name": "keyword.operator.pipeline.seseragi",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.application.seseragi",
          "match": "\\$"
        },
        {
          "name": "keyword.operator.signal.seseragi",
          "match": ":="
        },
        {
          "name": "keyword.operator.assignment.seseragi",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.seseragi",
          "match": "(\\*\\*|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.cons.seseragi",
          "match": ":"
        },
        {
          "name": "keyword.operator.nullish-coalescing.seseragi",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.lambda.seseragi",
          "match": "\\\\"
        },
        {
          "name": "punctuation.separator.variant.seseragi",
          "match": "\\|"
        },
        {
          "name": "punctuation.accessor.seseragi",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.optional-field.seseragi",
          "match": "\\?(?=\\s*[:,}])"
        },
        {
          "name": "keyword.operator.custom.seseragi",
          "match": "[!$%&*+\\-./:<=>?@^|~]{2,}"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.io.seseragi",
          "match": "\\b(print|println|printValue|show)(?=\\s*\\()"
        },
        {
          "name": "support.function.builtin.io.functional.seseragi",
          "match": "\\b(print|println|printValue|show)(?=\\s+[^\\(])"
        },
        {
          "name": "support.function.builtin.io.standalone.seseragi",
          "match": "\\b(print|println|printValue|show)(?=\\s*$)"
        },
        {
          "name": "entity.name.function.definition.seseragi",
          "match": "(?<=fn\\s+)[a-z][a-zA-Z0-9_]*'*"
        },
        {
          "name": "entity.name.function.call.seseragi",
          "match": "\\b[a-z][a-zA-Z0-9_]*'*(?=\\s*\\()"
        },
        {
          "name": "support.function.builtin.seseragi",
          "match": "\\b(Just|Nothing|Left|Right|Cons|Nil)\\b"
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.seseragi",
          "begin": "(?<![\\p{L}\\p{N}_'])'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.seseragi",
              "match": "\\\\(?:[\\\\'nrt0]|u\\{[0-9A-Fa-f]{1,6}\\})"
            },
            {
              "name": "invalid.illegal.escape.seseragi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.seseragi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.seseragi",
              "match": "\\\\(?:[\\\\\"nrt0]|u\\{[0-9A-Fa-f]{1,6}\\})"
            },
            {
              "name": "invalid.illegal.escape.seseragi",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.seseragi",
          "begin": "`(?!\\[)",
          "end": "`",
          "patterns": [
            {
              "name": "meta.embedded.expression.seseragi",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.template-expression.begin.seseragi"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.template-expression.end.seseragi"
                }
              },
              "patterns": [
                {
                  "include": "#expressions"
                }
              ]
            },
            {
              "name": "constant.character.escape.seseragi",
              "match": "\\\\(?:[\\\\`nrt0]|u\\{[0-9A-Fa-f]{1,6}\\}|\\$\\{)"
            },
            {
              "name": "invalid.illegal.escape.seseragi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.seseragi",
          "match": "(?<![A-Za-z0-9_])(?:0|[1-9][0-9]*(?:_[0-9]+)*)(?:\\.[0-9]+(?:_[0-9]+)*(?:[eE][+-]?[0-9]+(?:_[0-9]+)*)?|[eE][+-]?[0-9]+(?:_[0-9]+)*)(?![A-Za-z0-9_])"
        },
        {
          "name": "constant.numeric.integer.seseragi",
          "match": "(?<![A-Za-z0-9_])(?:0[bB][01]+(?:_[01]+)*|0[oO][0-7]+(?:_[0-7]+)*|0[xX][0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*|0|[1-9][0-9]*(?:_[0-9]+)*)(?![A-Za-z0-9_])"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.seseragi",
          "match": "\\b(True|False)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "constant.language.wildcard.seseragi",
          "match": "\\b_\\b"
        },
        {
          "name": "variable.other.seseragi",
          "match": "\\b[a-z][a-zA-Z0-9_]*'*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.parenthesis.begin.seseragi",
          "match": "\\("
        },
        {
          "name": "punctuation.parenthesis.end.seseragi",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.begin.seseragi",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.end.seseragi",
          "match": "\\]"
        },
        {
          "name": "punctuation.brace.begin.seseragi",
          "match": "\\{"
        },
        {
          "name": "punctuation.brace.end.seseragi",
          "match": "\\}"
        },
        {
          "name": "punctuation.separator.comma.seseragi",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.seseragi",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.seseragi",
          "match": ";"
        },
        {
          "name": "punctuation.backtick.seseragi",
          "match": "`"
        }
      ]
    },
    "list-sugar": {
      "patterns": [
        {
          "name": "meta.list-sugar.seseragi",
          "begin": "`\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.list.begin.seseragi"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.list.end.seseragi"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#identifiers"
            },
            {
              "include": "#list-sugar"
            },
            {
              "name": "punctuation.separator.comma.seseragi",
              "match": ","
            }
          ]
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#functions"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#booleans"
        },
        {
          "include": "#identifiers"
        },
        {
          "include": "#punctuation"
        }
      ]
    }
  }
}
