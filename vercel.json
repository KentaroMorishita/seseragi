{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/playground && bun run build",
  "outputDirectory": "apps/playground/dist",
  "installCommand": "cd apps/playground && bun install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
